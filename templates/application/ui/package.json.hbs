{
  "name": "@kalisio/{{ name }}-ui",
  "description": "{{ description }} (ui package)",
  "version": "0.0.0",
  "type": "module",
  "keywords": [
    "{{ name }}",
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kalisio/{{ monorepo }}.git",
    "directory": "packages/{{ name }}"
  },
  "bugs": {
    "url": "https://github.com/kalisio/{{ monorepo }}/issues"
  },
  "homepage": "https://github.com/kalisio/{{ monorepo }}/tree/main/packages/{{ name }}-ui",
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "dev": "cross-env NODE_ENV=development quasar dev",
    "build": "quasar build",
    "pwa:dev": "quasar dev -m pwa",
    "pwa:build": "quasar build -m pwa",
    "postinstall": "quasar prepare",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@kalisio/feathers-localforage": "catalog:",
    "@kalisio/kdk": "catalog:",
    "@quasar/extras": "catalog:",
    "@thumbmarkjs/thumbmarkjs": "catalog:",
    "ajv": "catalog:",
    "ajv-i18n": "catalog:",
    "config": "catalog:",
    "feathers-reactive": "catalog:",
    "jwt-decode": "catalog:",
    "lodash": "catalog:",
    "path-browserify": "catalog:",
    "quasar": "catalog:",
    "register-service-worker": "catalog:",
    "vue": "catalog:",
    "vue-i18n": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@quasar/app-vite": "catalog:",
    "@vue/eslint-config-prettier": "catalog:",
    "autoprefixer": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "globals": "catalog:",
    "postcss": "catalog:",
    "prettier": "catalog:",
    "vite-plugin-checker": "catalog:",
    "vue-eslint-parser": "catalog:",
    "workbox-build": "catalog:",
    "workbox-cacheable-response": "catalog:",
    "workbox-core": "catalog:",
    "workbox-expiration": "catalog:",
    "workbox-precaching": "catalog:",
    "workbox-routing": "catalog:",
    "workbox-strategies": "catalog:"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
}