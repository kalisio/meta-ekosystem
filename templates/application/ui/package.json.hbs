{
  "name": "@kalisio/{{ name }}-ui",
  "description": "{{ description }} (ui package)",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "{{packageManager}}",
  "standard": {
    "globals": [
      "self"
    ]
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development quasar dev",
    "build": "quasar build",
    "lint": "standard --fix",
    "pwa:dev": "quasar dev -m pwa",
    "pwa:build": "quasar build -m pwa",
    "postinstall": "quasar prepare",
    "test": "vitest run --coverage"
  },
  "keywords": [
    "{{ name }}"
  ],
  "author": {
    "name": "{{ authorName }}",
    "email": "{{ authorEmail }}",
    "url": "{{ authorUrl }}"
  },
  "contributors": [],
  "license": "{{#if license}}MIT{{else}}UNLICENSED{{/if}}",
  "repository": {
    "type": "git",
    "url": "git+{{ monorepoUrl }}/{{ monorepoName }}.git",
    "directory": "packages/{{ name }}-ui"
  },
  "bugs": {
    "url": "{{ monorepoUrl }}/{{ monorepoName }}/issues"
  },
  "homepage": "{{ monorepoUrl }}/{{ monorepoName }}/tree/main/packages/{{ name }}-ui",
  "dependencies": {
    "@kalisio/feathers-localforage": "catalog:",
    "@kalisio/kdk": "catalog:",
    "@quasar/extras": "catalog:",
    "@thumbmarkjs/thumbmarkjs": "catalog:",
    "ajv": "catalog:",
    "ajv-i18n": "catalog:",
    "config": "catalog:",
    "feathers-reactive": "catalog:",
    "jwt-decode": "catalog:",
    "lodash": "catalog:",
    "path-browserify": "catalog:",
    "quasar": "catalog:",
    "register-service-worker": "catalog:",
    "vue": "catalog:",
    "vue-i18n": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@quasar/app-vite": "catalog:",
    "@vue/eslint-config-prettier": "catalog:",
    "autoprefixer": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "globals": "catalog:",
    "postcss": "catalog:",
    "prettier": "catalog:",
    "vite-plugin-checker": "catalog:",
    "vue-eslint-parser": "catalog:",
    "workbox-build": "catalog:",
    "workbox-cacheable-response": "catalog:",
    "workbox-core": "catalog:",
    "workbox-expiration": "catalog:",
    "workbox-precaching": "catalog:",
    "workbox-routing": "catalog:",
    "workbox-strategies": "catalog:"
  },
  "engines": {
    "node": "^24 || ^22",
    "pnpm": ">=10"
  }
}