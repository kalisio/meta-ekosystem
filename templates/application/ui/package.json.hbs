{
  "name": "@kalisio/{{ name }}-ui",
  "description": "{{ description }} (ui package)",
  "version": "0.0.0",
  "type": "module",
  "keywords": [
    "{{ name }}",
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kalisio/{{ monorepo }}.git",
    "directory": "packages/{{ name }}"
  },
  "bugs": {
    "url": "https://github.com/kalisio/{{ monorepo }}/issues"
  },
  "homepage": "https://github.com/kalisio/{{ monorepo }}/tree/main/packages/{{ name }}-ui",
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "dev": "cross-env NODE_ENV=development quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@kalisio/kdk": "catalog:",
    "@kalisio/feathers-localforage": "catalog:",
    "@quasar/extras": "catalog:",
    "config": "catalog:",
    "feathers-reactive": "catalog:",
    "jwt-decode": "catalog:",
    "lodash": "catalog:",
    "path-browserify": "catalog:",
    "quasar": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.4.0",
    "vite-plugin-checker": "^0.11.0",
    "vue-eslint-parser": "^10.2.0",
    "@vue/eslint-config-prettier": "^10.1.0",
    "prettier": "^3.8.1",
    "@quasar/app-vite": "catalog:",
    "autoprefixer": "^10.4.2",
    "postcss": "^8.4.14"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
}