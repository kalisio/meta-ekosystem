{
  "name": "@kalisio/{{ name }}-common",
  "description": "{{ description }} (common package)",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "{{ packageManager }}",
  "exports": "./src/index.js",
  "scripts": {
    "test": "vitest run --coverage"
  },
  "keywords": [
    "{{ name }}"
  ],
  "author": {
    "name": "{{ authorName }}",
    "email": "{{ authorEmail }}",
    "url": "{{ authorUrl }}"
  },
  "contributors": [],
  "license": "{{#if license}}MIT{{else}}UNLICENSED{{/if}}",
  "repository": {
    "type": "git",
    "url": "git+{{ monorepoUrl }}/{{ monorepoName }}.git",
    "directory": "packages/{{ name }}-common"
  },
  "bugs": {
    "url": "{{ monorepoUrl }}/{{ monorepoName }}/issues"
  },
  "homepage": "{{ monorepoUrl }}/{{ monorepoName }}/tree/main/packages/{{ name }}-common",
  "dependencies": {
    "lodash-es": "catalog:"
  },
  "devDependencies": {},
  "engines": {
    "node": "^24 || ^22",
    "pnpm": ">=10"
  }
}