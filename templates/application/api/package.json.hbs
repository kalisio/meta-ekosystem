{
  "name": "@kalisio/{{ name }}-api",
  "description": "{{ description }} (api package)",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node --watch src/index.js",
    "test": "vitest run --coverage"
  },
  "keywords": [
    "{{ name }}",
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://kalisio.com"
  },
  "contributors": [],
  "license": "{{#if license}}MIT{{else}}UNLICENSED{{/if}}",
  "repository": {
    "type": "git",
    "url": "git+{{ monorepoUrl }}/{{ monorepoName }}.git",
    "directory": "packages/{{ name }}-api"
  },
  "bugs": {
    "url": "{{ monorepoUrl }}/{{ monorepoName }}/issues"
  },
  "homepage": "{{ monorepoUrl }}/{{ monorepoName }}/tree/main/packages/{{ name }}-api",
  "dependencies": {
    "@feathersjs/authentication": "catalog:",
    "@feathersjs/express": "catalog:",
    "@kalisio/feathers-distributed": "catalog:",
    "@kalisio/kdk": "catalog:",
    "@kalisio/{{ name }}-common": "workspace:*",
    "debug": "catalog:",
    "feathers-hooks-common": "catalog:",
    "is-docker": "catalog:",
    "lodash": "catalog:",
    "winston": "catalog:"
  },
  "devDependencies": {},
  "engines": {
    "node": "^24 || ^22",
    "pnpm": ">=10"
  }
}