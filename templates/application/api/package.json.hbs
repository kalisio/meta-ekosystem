{
  "name": "@kalisio/{{ name }}-api",
  "description": "{{ description }} (api package)",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node --watch src/index.js",
    "test": "vitest run --coverage"
  },
  "keywords": [
    "{{ name }}",
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kalisio/{{ monorepo }}.git",
    "directory": "packages/{{ name }}"
  },
  "bugs": {
    "url": "https://github.com/kalisio/{{ monorepo }}/issues"
  },
  "homepage": "https://github.com/kalisio/{{ monorepo }}/tree/main/packages/{{ name }}-api",
  "dependencies": {
    "@feathersjs/authentication": "catalog:",
    "@feathersjs/express": "catalog:",
    "@kalisio/feathers-distributed": "catalog:",
    "@kalisio/kdk": "catalog:",
    "@kalisio/{{ name }}-common": "workspace:*",
    "debug": "catalog:",
    "feathers-hooks-common": "catalog:",
    "is-docker": "catalog:",
    "lodash": "catalog:",
    "winston": "catalog:"
  },
  "devDependencies": {}
}