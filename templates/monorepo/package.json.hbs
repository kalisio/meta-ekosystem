{
  "name": "{{ name }}",
  "description": "{{ description }}",
  "type": "module",
  "packageManager": "pnpm@10.1.0",
  "scripts": {
    "build": "pnpm -r build",
    "bump": "changeset version",
    "change": "changeset",
    "clear": "pnpm -r exec rimraf node_modules dist coverage",
    "docs:build": "pnpm --filter docs run build",
    "docs:dev": "pnpm --filter docs run dev",
    "inspect": "pnpm knip",
    "lint": "pnpm -r lint",
    "prepare": "husky",
    "prerelease": "pnpm build",
    "release": "changeset publish",
    "postrelease": "git push --follow-tags",
    "pretest": "mkdir -p coverage",
    "test": "pnpm -r test --coverage",
    "posttest": "pnpm lcov-result-merger --prepend-source-files 'packages/*/coverage/lcov.info' coverage/lcov.info"
  },
  "keywords": [
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalisio/{{ name }}.git"
  },
  "bugs": {
    "url": "https://github.com/kalisio/{{ name }}/issues"
  },
  "homepage": "git://github.com/kalisio/{{ name }}#readme",
  "devDependencies": {
   "@changesets/cli": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "husky": "catalog:",
    "knip": "catalog:",
    "lcov-result-merger": "catalog:",
    "lint-staged": "catalog:",
    "publint": "catalog:",
    "rimraf": "catalog:",
    "standard": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
