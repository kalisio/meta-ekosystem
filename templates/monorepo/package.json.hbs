{
  "name": "{{ name }}",
  "description": "{{ description }}",
  "type": "module",
  "packageManager": "pnpm@10.1.0",
  "scripts": {
    "build": "pnpm -r build",
    "bump": "changeset version",
    "change": "changeset",
    "clear": "pnpm -r exec rimraf node_modules dist coverage",
    {{~#if documentation}}
    "docs:build": "pnpm --filter docs run build",
    "docs:dev": "pnpm --filter docs run dev",
    {{~/if}}
    "inspect": "pnpm knip",
    "lint": "pnpm -r lint",
    "prepare": "husky",
    "prerelease": "pnpm build",
    "release": "changeset publish",
    "postrelease": "git push --follow-tags",
    "pretest": "mkdir -p coverage",
    "test": "pnpm -r test --coverage",
    "posttest": "pnpm lcov-result-merger --prepend-source-files 'packages/*/coverage/lcov.info' coverage/lcov.info"
  },
  "keywords": [
    "kalisio"
  ],
 "author": {
    "name": "{{authorName}}",
    "email": "{{authorEmail}}",
    "url": "{{authorUrl}}",
    "logo": "{{authorLogo}}"
  },
  "contributors": [],
  "license": "{{#if license}}MIT{{else}}UNLICENSED{{/if}}",
  "repository": {
    "type": "git",
    "url": "git+{{repoUrl}}/{{ name }}.git"
  },
  "bugs": {
    "url": "{{repoUrl}}/{{ name }}/issues"
  },
  "homepage": "{{#if documentation}}{{docsUrl}}{{else}}{{repoUrl}}/{{ name }}#readme{{/if}}",
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "husky": "catalog:",
    "knip": "catalog:",
    "lcov-result-merger": "catalog:",
    "lint-staged": "catalog:",
    "publint": "catalog:",
    "rimraf": "catalog:",
    "standard": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}